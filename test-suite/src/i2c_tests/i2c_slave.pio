.program i2c_slave
.side_set 1 opt pindirs
 
; pin 0 is SDA
; pin 1 is SCL
wait_idle:
    wait 1 pin 0 ; Wait for SDA high (idle state)
    wait 1 pin 1 ; wait for SCL high (idle state)

wait_start:
    wait 0 pin 1   ; Wait for SCL low (potential start)

    ; Read 8 address bits (MSB first)
    set y, 7      ; Bit counter
read_addr:
    wait 1 pin 1  ; Wait for SCL high
    in pins 1     ; Read SDA
    wait 0 pin 1  ; Wait for SCL low
    jmp y-- read_addr ; Read bit and decrement y

    ; irq set 1

    ; Acknowledge the address
    set pins 0 side 1 [2]; Set SDA low (ACK)
    wait 1 pin 1 ; Wait for SCL high
    nop [7]
    wait 0 pin 1  ; Wait for SCL low
    irq set 2

  set y, 7
reply:
  ; TODO: rewrite to set data on SCL going DOWN instead of during the clock cycle
  wait 1 pin 1 ; wait for scl
  set pins, 1 ; set sda to one
  wait 0 pin 1; wait for scl
  jmp y-- reply

  nop side 0 ; switch pin dirs

  ; we expect a NAK + STOP
  wait 1 pin 1
  wait 0 pin 0

  irq set 3

  ; stop
  wait 1 pin 1
  wait 1 pin 0

  irq set 3

