.program i2c_slave
.side_set 1 opt pindirs
 
; pin 0 is SDA
; pin 1 is SCL
wait_idle:
    wait 1 pin 0 ; Wait for SDA high (idle state)
    wait 1 pin 1 ; wait for SCL high (idle state)

wait_start:
  wait 0 pin 1   ; Wait for SCL low (start condition)

  ; Read 7 address bits
  set y, 6      ; Bit counter
read_addr:
  wait 1 pin 1  ; Wait for SCL high
  in pins 1     ; Read SDA
  wait 0 pin 1  ; Wait for SCL low
  jmp y-- read_addr ; Read bit and decrement y

  ; Read R/W bit
  wait 1 pin 1; SCL high
  in pins 1
  jmp pin set_read
  set x, 0 ; set write
  jmp done_set
set_read:
  set x, 1; set read
done_set:
  wait 0 pin 1 [7] ; SCL low

addr_ack:
  ; Acknowledge the address
  set pins 0 side 1; Set SDA low (ACK)

  wait 1 pin 1 ; Wait for SCL high
  wait 0 pin 1 [7]  ; Wait for SCL low

  ; use x to determine Write (0) or Read (1)
  set y, 7; Init counter to count down write or read

  jmp !x read side 0
  jmp read side 1
read:
  out pins, 1; shift one bit out from OSR to pins (pin 0, sda)
  wait 1 pin 1 ; wait for scl
  in pins, 1 ; Read SDA
  wait 0 pin 1 [7] ; wait for scl
  jmp y-- read

  jmp !x write_ack side 1 [7]
  jmp done side 0
write_ack:
  set pins 0 

  wait 1 pin 1
  wait 0 pin 1 side 0

  ; NAK
  ; wait 1 pin 1
  ; wait 0 pin 0

done:
  ; stop
  ; wait 1 pin 1
  ; wait 1 pin 0

  irq wait 3
