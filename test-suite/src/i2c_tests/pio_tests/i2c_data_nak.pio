.program address_nak
.side_set 1 opt pindirs
 
; pin 0 is SDA
; pin 1 is SCL
;wait_idle:
;    wait 1 pin 0 ; Wait for SDA high (idle state)
;    wait 1 pin 1 ; wait for SCL high (idle state)

  wait 0 pin 1   ; Wait for SCL low (start condition)

  ; Read 7 address bits
  set y, 6      ; Bit counter
read_addr:
  wait 1 pin 1  ; Wait for SCL high
  in pins 1     ; Read SDA
  wait 0 pin 1  ; Wait for SCL low
  jmp y-- read_addr ; Read bit and decrement y

  ; Read R/W bit
  wait 1 pin 1; SCL high
  in pins 1
  jmp pin set_read
  set x, 0 ; set write
  jmp done_set
set_read:
  set x, 1; set read
done_set:
  wait 0 pin 1 [7] side 1 ; SCL low

addr_ack:
  ; do not acknowledge the address
  set pins 1 side 1; Set SDA HIGH (NACK)

  wait 1 pin 1 ; Wait for SCL high
  wait 0 pin 1 [7]  ; Wait for SCL low

  irq wait 0

