.program i2c_slave
.side_set 1 opt pindirs
 
; pin 0 is SDA
; pin 1 is SCL
;wait_idle:
;    wait 1 pin 0 ; Wait for SDA high (idle state)
;    wait 1 pin 1 ; wait for SCL high (idle state)

.wrap_target
  wait 0 pin 1   ; Wait for SCL low (start condition)

  ; Read 7 address bits
  set y, 6      ; Bit counter
read_addr:
  wait 1 pin 1  ; Wait for SCL high
  in pins 1     ; Read SDA
  wait 0 pin 1  ; Wait for SCL low
  jmp y-- read_addr ; Read bit and decrement y

  ; Read R/W bit
  wait 1 pin 1; SCL high
  in pins 1
  jmp pin set_read
  set x, 0 ; set write
  jmp done_set
set_read:
  set x, 1; set read
done_set:
  wait 0 pin 1 [7] ; SCL low

addr_ack:
  ; Acknowledge the address
  set pins 0 side 1; Set SDA low (ACK)

  wait 1 pin 1 ; Wait for SCL high
  wait 0 pin 1 [7]  ; Wait for SCL low

pre_byte:
  set y, 7; Init counter to count down write or read

  ; use x to determine Write (0) or Read (1)
  jmp !x byte side 0
  nop side 1
byte:
  out pins, 1; shift one bit out from OSR to pins (pin 0, SDA)
  wait 1 pin 1 ; wait for SCL
  in pins, 1 ; Read SDA
  wait 0 pin 1 [7] ; wait for SCL
  jmp y-- byte

  jmp !x write_ack side 1
  jmp done side 0
write_ack:
  ; I Could use addr_ack iff im expecting more bytes after this
  set pins 0 

  ; TODO: verify Ack/Nack on read (?)
  wait 1 pin 1
  wait 0 pin 1 side 0

done:
  ; wait 1 pin 1 ; <-- Feels wrong but makes the waveform happy
  ; stop
  ; wait 1 pin 1
  ; wait 1 pin 0 line wh

  irq wait 3 side 0

.wrap
